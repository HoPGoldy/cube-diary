// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./client/"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  ADMIN
}

model AppConfig {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id        String   @id @default(uuid())
  userId    String
  filename  String
  size      Int
  hash      String
  path      String
  thumbPath String? // 图片类型的附件会有缩略图
  thumbSize Int?
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// MCP 访问令牌
model AccessToken {
  id          String    @id @default(uuid())
  name        String
  tokenHash   String    @unique
  tokenPrefix String // 明文前8位，仅用于展示
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
}

// 日记 - 单用户系统
model Diary {
  dateStr   String   @id // "20251224" - 用户本地日期，作为主键
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  date    BigInt  @unique // 毫秒级时间戳 (UTC 0)，用于范围查询和排序
  content String  @default("")
  color   String? // 颜色标签

  @@index([date])
}
